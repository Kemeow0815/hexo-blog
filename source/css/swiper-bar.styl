// Swiper Bar 轮播组件样式 - 适配 Stellar 主题

// 轮播容器
.swiper-bar-container
  width: 100%
  margin: 1rem 0
  border-radius: 24px
  overflow: hidden
  background: var(--block)
  box-shadow: $boxshadow-card
  hoverable-card()
  z-index: 0

// Swiper 主体
.blog-slider
  width: 100%
  position: relative

// 轮播项
.blog-slider__item
  display: flex
  align-items: center
  padding: 20px
  gap: 20px
  background: var(--block)
  
  @media screen and (max-width: 768px)
    flex-direction: column
    padding: 16px
    gap: 16px

// 图片区域
.blog-slider__img
  width: 280px
  height: 180px
  flex-shrink: 0
  border-radius: 16px
  overflow: hidden
  position: relative
  
  img
    width: 100%
    height: 100%
    object-fit: cover
    border-radius: 16px
    transition: transform 0.3s ease
  
  &:hover img
    transform: scale(1.05)
  
  @media screen and (max-width: 768px)
    width: 100%
    height: 200px
  
  @media screen and (max-width: 480px)
    height: 160px

// 内容区域
.blog-slider__content
  flex: 1
  min-width: 0
  display: flex
  flex-direction: column
  justify-content: center

// 标题
.blog-slider__title
  font-size: 1.25rem
  font-weight: 600
  color: var(--text-p1)
  margin-bottom: 12px
  line-height: 1.4
  display: -webkit-box
  -webkit-line-clamp: 2
  -webkit-box-orient: vertical
  overflow: hidden
  
  a
    color: inherit
    text-decoration: none
    transition: color 0.2s ease
    
    &:hover
      color: var(--accent)
  
  @media screen and (max-width: 768px)
    font-size: 1.1rem
    margin-bottom: 8px

// 描述
.blog-slider__desc
  font-size: 0.9rem
  color: var(--text-p2)
  line-height: 1.6
  margin-bottom: 16px
  display: -webkit-box
  -webkit-line-clamp: 2
  -webkit-box-orient: vertical
  overflow: hidden
  
  @media screen and (max-width: 768px)
    font-size: 0.85rem
    margin-bottom: 12px
    -webkit-line-clamp: 3

// 元信息
.blog-slider__meta
  display: flex
  align-items: center
  gap: 16px
  font-size: 0.8rem
  color: var(--text-p3)
  
  .meta-item
    display: flex
    align-items: center
    gap: 4px
    
    svg
      width: 14px
      height: 14px
      fill: currentColor
  
  @media screen and (max-width: 480px)
    gap: 12px
    font-size: 0.75rem

// 导航按钮
.blog-slider__button
  position: absolute
  top: 50%
  transform: translateY(-50%)
  width: 40px
  height: 40px
  border-radius: 50%
  background: var(--card)
  border: 1px solid var(--block-border)
  color: var(--text-p2)
  cursor: pointer
  display: flex
  align-items: center
  justify-content: center
  transition: all 0.2s ease
  z-index: 10
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1)
  
  &:hover
    background: var(--accent)
    color: #fff
    border-color: var(--accent)
  
  svg
    width: 20px
    height: 20px
    fill: currentColor
  
  &--prev
    left: 10px
  
  &--next
    right: 10px
  
  @media screen and (max-width: 768px)
    width: 32px
    height: 32px
    
    svg
      width: 16px
      height: 16px
    
    &--prev
      left: 8px
    
    &--next
      right: 8px

// 分页器
.blog-slider__pagination
  position: absolute
  bottom: 16px
  left: 50%
  transform: translateX(-50%)
  display: flex
  gap: 8px
  z-index: 10
  
  .swiper-pagination-bullet
    width: 8px
    height: 8px
    border-radius: 4px
    background: var(--text-p3)
    opacity: 0.4
    cursor: pointer
    transition: all 0.3s ease
    
    &-active
      width: 24px
      opacity: 1
      background: var(--accent)
  
  @media screen and (max-width: 768px)
    bottom: 12px
    
    .swiper-pagination-bullet
      width: 6px
      height: 6px
      
      &-active
        width: 20px

// 置顶标记
.blog-slider__pin
  position: absolute
  top: 12px
  left: 12px
  background: var(--accent)
  color: #fff
  padding: 4px 10px
  border-radius: 12px
  font-size: 0.7rem
  font-weight: 500
  display: flex
  align-items: center
  gap: 4px
  z-index: 5
  
  svg
    width: 12px
    height: 12px
    fill: currentColor

// 深色模式适配
[data-theme="dark"]
  .swiper-bar-container
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2)
  
  .blog-slider__button
    background: var(--card)
    border-color: var(--block-border)
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3)

// 动画效果
.blog-slider__item
  opacity: 0
  transform: translateX(30px)
  transition: all 0.4s ease
  
  &.swiper-slide-active
    opacity: 1
    transform: translateX(0)
