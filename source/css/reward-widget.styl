// Reward Widget 能量榜侧边栏组件样式

.reward-widget
  background: var(--card)
  border-radius: $border-card-s
  padding: 1rem
  border: 1px solid var(--block-border)
  box-shadow: $boxshadow-card

// 头部
.reward-header
  display: flex
  align-items: center
  justify-content: space-between
  margin-bottom: 1rem

.reward-title-wrapper
  display: flex
  align-items: center
  gap: 0.5rem

.reward-icon
  color: var(--accent)

.reward-title
  font-size: 1rem
  font-weight: 600
  color: var(--text-p1)

.reward-goto
  padding: 0.375rem 0.75rem
  background: rgba(0, 0, 0, 0.6)
  color: #fff
  border-radius: 16px
  font-size: 0.75rem
  text-decoration: none
  transition: all 0.2s ease

  &:hover
    background: rgba(0, 0, 0, 0.8)

// 主卡片区域
.reward-card
  margin-bottom: 1rem

.reward-card-inner
  min-height: 80px

.reward-loading
  color: var(--text-p3)
  font-size: 0.875rem
  text-align: center
  padding: 1rem 0

// 主卡片项
.reward-card-item
  display: flex
  align-items: center
  gap: 0.75rem
  padding: 0.75rem
  background: var(--block)
  border-radius: 12px
  cursor: default
  animation: reward-card-fade 0.3s ease

@keyframes reward-card-fade
  from
    opacity: 0
    transform: translateY(5px)
  to
    opacity: 1
    transform: translateY(0)

// 可点击的主卡片
.reward-card-item-link
  cursor: pointer
  transition: all 0.2s ease

  &:hover
    background: var(--accent)
    
    .reward-card-name
      color: #fff
    
    .reward-card-desc
      color: rgba(255, 255, 255, 0.8)

.reward-card-avatar
  width: 48px
  height: 48px
  border-radius: 50%
  overflow: hidden
  flex-shrink: 0

  img
    width: 100%
    height: 100%
    object-fit: cover

.reward-card-info
  display: flex
  flex-direction: column
  gap: 0.25rem
  min-width: 0

.reward-card-name
  font-size: 1rem
  font-weight: 600
  color: var(--text-p1)
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

.reward-card-desc
  font-size: 0.75rem
  color: var(--text-p3)

// 简化列表
.reward-list
  display: flex
  flex-wrap: wrap
  gap: 0.5rem
  margin-bottom: 1rem
  padding: 0.5rem 0
  border-top: 1px solid var(--block-border)
  border-bottom: 1px solid var(--block-border)

.reward-list-item
  font-size: 0.8125rem
  color: var(--text-p2)
  text-decoration: underline
  text-decoration-style: dashed
  text-underline-offset: 3px
  transition: all 0.2s ease
  cursor: pointer

  &:hover
    color: var(--accent)
    text-decoration-style: solid

// 底部文字
.reward-footer
  text-align: center

.reward-thanks
  font-size: 0.8125rem
  color: var(--text-p2)
  margin-bottom: 0.5rem

.reward-note
  font-size: 0.75rem
  color: var(--text-p3)

// 深色模式适配
[data-theme="dark"]
  .reward-goto
    background: rgba(255, 255, 255, 0.15)
    
    &:hover
      background: rgba(255, 255, 255, 0.25)

// 移动端适配
@media screen and (max-width: 768px)
  .reward-widget
    padding: 0.875rem

  .reward-card-avatar
    width: 40px
    height: 40px

  .reward-card-name
    font-size: 0.9375rem

  .reward-list-item
    font-size: 0.75rem
