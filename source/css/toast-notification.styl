// Toast Notification 通知悬浮窗样式

// 通知容器
.toast-container
  position: fixed
  display: flex
  flex-direction: column
  gap: 12px
  pointer-events: none
  z-index: 9999
  
  // 四个位置
  &.top-left
    top: 20px
    left: 20px
    align-items: flex-start
  
  &.top-right
    top: 20px
    right: 20px
    align-items: flex-end
  
  &.bottom-left
    bottom: 20px
    left: 20px
    align-items: flex-start
    flex-direction: column-reverse
  
  &.bottom-right
    bottom: 20px
    right: 20px
    align-items: flex-end
    flex-direction: column-reverse
  
  @media screen and (max-width: 768px)
    &.top-left,
    &.top-right
      top: 10px
      right: 10px
      left: 10px
      align-items: stretch
    
    &.bottom-left,
    &.bottom-right
      bottom: 10px
      right: 10px
      left: 10px
      align-items: stretch

// 通知项
.toast-item
  display: flex
  align-items: center
  gap: 12px
  padding: 14px 18px
  min-width: 280px
  max-width: 400px
  background: var(--card)
  border-radius: $border-card
  box-shadow: $boxshadow-card-float
  pointer-events: auto
  transform: translateX(120%)
  opacity: 0
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55)
  border-left: 4px solid transparent
  position: relative
  overflow: hidden
  
  @media screen and (max-width: 768px)
    min-width: unset
    max-width: 100%
    width: 100%
    transform: translateY(-20px)
  
  // 显示状态
  &.show
    transform: translateX(0)
    opacity: 1
    
    @media screen and (max-width: 768px)
      transform: translateY(0)
  
  // 隐藏状态
  &.hide
    transform: translateX(120%)
    opacity: 0
    
    @media screen and (max-width: 768px)
      transform: translateY(-20px)

// 左侧位置的通知从左边滑入
.toast-container.top-left,
.toast-container.bottom-left
  .toast-item
    transform: translateX(-120%)
    
    &.show
      transform: translateX(0)
    
    &.hide
      transform: translateX(-120%)

// 图标
.toast-icon
  flex-shrink: 0
  width: 24px
  height: 24px
  display: flex
  align-items: center
  justify-content: center
  border-radius: 50%
  
  svg
    width: 16px
    height: 16px
    fill: currentColor

// 内容
.toast-content
  flex: 1
  min-width: 0

.toast-title
  font-weight: 600
  font-size: 0.95rem
  color: var(--text-p1)
  margin-bottom: 4px
  line-height: 1.3

.toast-message
  font-size: 0.85rem
  color: var(--text-p2)
  line-height: 1.4
  word-wrap: break-word

// 自定义按钮
.toast-action-btn
  margin-top: 10px
  padding: 6px 12px
  background: var(--accent)
  color: #fff
  border: none
  border-radius: $border-card-s
  font-size: 0.8rem
  font-weight: 500
  cursor: pointer
  display: inline-flex
  align-items: center
  gap: 6px
  transition: all 0.2s ease
  
  &:hover
    opacity: 0.9
    transform: translateY(-1px)
  
  .btn-icon
    display: inline-flex
    align-items: center
    
    svg
      width: 14px
      height: 14px
      fill: currentColor
  
  .btn-text
    white-space: nowrap

// 关闭按钮
.toast-close
  flex-shrink: 0
  width: 24px
  height: 24px
  display: flex
  align-items: center
  justify-content: center
  border: none
  background: transparent
  color: var(--text-p3)
  cursor: pointer
  border-radius: 4px
  transition: all 0.2s ease
  
  svg
    width: 16px
    height: 16px
    fill: currentColor
  
  &:hover
    background: var(--block)
    color: var(--text-p1)

// 进度条
.toast-progress
  position: absolute
  bottom: 0
  left: 0
  height: 3px
  background: currentColor
  opacity: 0.3
  border-radius: 0 0 0 $border-card
  transition: width 0.1s linear

// 类型样式
.toast-item
  &.toast-success
    border-left-color: #10b981
    
    .toast-icon
      background: rgba(16, 185, 129, 0.1)
      color: #10b981
    
    .toast-progress
      color: #10b981
  
  &.toast-error
    border-left-color: #ef4444
    
    .toast-icon
      background: rgba(239, 68, 68, 0.1)
      color: #ef4444
    
    .toast-progress
      color: #ef4444
  
  &.toast-warning
    border-left-color: #f59e0b
    
    .toast-icon
      background: rgba(245, 158, 11, 0.1)
      color: #f59e0b
    
    .toast-progress
      color: #f59e0b
  
  &.toast-info
    border-left-color: #3b82f6
    
    .toast-icon
      background: rgba(59, 130, 246, 0.1)
      color: #3b82f6
    
    .toast-progress
      color: #3b82f6

// 深色模式适配
[data-theme="dark"]
  .toast-item
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4)
    
    &.toast-success
      .toast-icon
        background: rgba(16, 185, 129, 0.2)
    
    &.toast-error
      .toast-icon
        background: rgba(239, 68, 68, 0.2)
    
    &.toast-warning
      .toast-icon
        background: rgba(245, 158, 11, 0.2)
    
    &.toast-info
      .toast-icon
        background: rgba(59, 130, 246, 0.2)
